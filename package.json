{
  "name": "nanobanana",
  "version": "0.1.0",
  "type": "module",
  "description": "AI image generation via Google Gemini — direct API, no CLI wrapper",
  "license": "MIT",
  "bin": {
    "nanobanana": "./bin/nanobanana"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.17.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "typescript": "~5.8.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
